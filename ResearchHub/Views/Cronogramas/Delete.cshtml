@model ResearchHub.Models.Cronograma
@{
    ViewData["Title"] = "Eliminar fase";
}

<div class="rh-delete-wrap">
    <h1 class="rh-delete-title">Eliminar fase de cronograma</h1>
    <p class="rh-warning">Esta accion no se puede deshacer.</p>

    <div class="rh-card">
        <div class="rh-field">
            <span class="rh-field-label">Fase</span>
            <span class="rh-field-value">@Model.NombreFase</span>
        </div>
        <div class="rh-field">
            <span class="rh-field-label">Proyecto</span>
            <span class="rh-field-value">@Model.Proyecto?.Titulo</span>
        </div>
        <div class="rh-field">
            <span class="rh-field-label">Dependencia</span>
            <span class="rh-field-value">@Model.Dependencia?.NombreFase</span>
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdCronograma" />
            <div class="rh-actions">
                <button class="rh-btn rh-btn-danger" type="submit">Eliminar</button>
                <a class="rh-btn rh-btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>
