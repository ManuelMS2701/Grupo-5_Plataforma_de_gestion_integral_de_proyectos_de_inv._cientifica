@model ResearchHub.Models.PagedListViewModel<ResearchHub.Models.Cronograma>
@{
    ViewData["Title"] = "Cronogramas";
    var hasPrev = Model.Page > 1;
    var hasNext = Model.Page < Model.TotalPages;
}

<div class="rh-list-wrap">
    <div class="rh-list-header">
        <h1 class="rh-list-title">Cronogramas</h1>
        <a class="rh-btn" asp-action="Create">Nueva fase</a>
    </div>

    <form method="get" class="rh-toolbar">
        <input class="form-control" type="text" name="q" value="@Model.Query" placeholder="Buscar por fase, estado, responsable o proyecto" />
        <select class="form-select" name="sort">
            <option value="inicio_desc" selected="@(Model.Sort == "inicio_desc")">Inicio desc</option>
            <option value="inicio_asc" selected="@(Model.Sort == "inicio_asc")">Inicio asc</option>
            <option value="fase_asc" selected="@(Model.Sort == "fase_asc")">Fase A-Z</option>
            <option value="fase_desc" selected="@(Model.Sort == "fase_desc")">Fase Z-A</option>
            <option value="avance_desc" selected="@(Model.Sort == "avance_desc")">Avance alto-bajo</option>
            <option value="hito_desc" selected="@(Model.Sort == "hito_desc")">Hitos primero</option>
        </select>
        <select class="form-select" name="pageSize">
            <option value="10" selected="@(Model.PageSize == 10)">10 / pagina</option>
            <option value="20" selected="@(Model.PageSize == 20)">20 / pagina</option>
            <option value="50" selected="@(Model.PageSize == 50)">50 / pagina</option>
        </select>
        <button class="rh-btn" type="submit">Filtrar</button>
        <a class="rh-btn rh-btn-secondary" asp-action="ExportCsv" asp-route-q="@Model.Query" asp-route-sort="@Model.Sort">Exportar CSV</a>
    </form>

    <div class="rh-meta">Mostrando @Model.FromItem-@Model.ToItem de @Model.TotalItems registros</div>

    <div class="rh-table">
        <table class="table rh-table-fixed">
            <thead>
                <tr>
                    <th>Fase</th>
                    <th>Avance</th>
                    <th>Hito</th>
                    <th>Proyecto</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Items.Any())
            {
                <tr><td colspan="5" class="rh-empty">No hay resultados para este filtro.</td></tr>
            }
            else
            {
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="rh-cell-clip" title="@item.NombreFase">@item.NombreFase</td>
                        <td><span class="rh-pill">@item.PorcentajeAvance%</span></td>
                        <td>@(item.EsHito ? "Sí" : "No")</td>
                        <td class="rh-cell-clip" title="@item.Proyecto?.Titulo">@item.Proyecto?.Titulo</td>
                        <td class="rh-row-actions">
                            <a asp-action="Edit" asp-route-id="@item.IdCronograma">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.IdCronograma">Detalles</a>
                            <a asp-action="Delete" asp-route-id="@item.IdCronograma">Eliminar</a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>

    <div class="rh-pager">
        <div>Pagina @Model.Page de @Model.TotalPages</div>
        <div class="rh-page-links">
            @if (hasPrev)
            {
                <a class="rh-page-link" asp-action="Index" asp-route-q="@Model.Query" asp-route-sort="@Model.Sort" asp-route-pageSize="@Model.PageSize" asp-route-page="@(Model.Page - 1)">Anterior</a>
            }
            @if (hasNext)
            {
                <a class="rh-page-link" asp-action="Index" asp-route-q="@Model.Query" asp-route-sort="@Model.Sort" asp-route-pageSize="@Model.PageSize" asp-route-page="@(Model.Page + 1)">Siguiente</a>
            }
        </div>
    </div>
</div>
