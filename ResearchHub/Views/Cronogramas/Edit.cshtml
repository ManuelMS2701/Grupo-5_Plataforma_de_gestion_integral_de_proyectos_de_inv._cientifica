@model ResearchHub.Models.Cronograma
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Editar fase";
}

<div class="rh-form-wrap">
    <h1 class="rh-form-title">Editar fase de cronograma</h1>
    <p class="rh-form-sub">Ajusta fechas, hitos, dependencias y avance.</p>

    <div class="rh-card">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdCronograma" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="rh-grid">
                <div class="rh-grid-full">
                    <label class="rh-label" asp-for="NombreFase"></label>
                    <input class="form-control rh-input" asp-for="NombreFase" />
                </div>
                <div>
                    <label class="rh-label" asp-for="IdProyecto">Proyecto</label>
                    <select class="form-select rh-input" asp-for="IdProyecto" asp-items="@(ViewData["IdProyecto"] as SelectList)"></select>
                </div>
                <div>
                    <label class="rh-label" asp-for="IdDependencia">Depende de</label>
                    <select class="form-select rh-input" asp-for="IdDependencia" asp-items="@(ViewData["IdDependencia"] as SelectList)">
                        <option value="">Sin dependencia</option>
                    </select>
                </div>
                <div>
                    <label class="rh-label" asp-for="FechaInicio"></label>
                    <input class="form-control rh-input" asp-for="FechaInicio" type="date" />
                </div>
                <div>
                    <label class="rh-label" asp-for="FechaFin"></label>
                    <input class="form-control rh-input" asp-for="FechaFin" type="date" />
                </div>
                <div>
                    <label class="rh-label" asp-for="Estado"></label>
                    <input class="form-control rh-input" asp-for="Estado" />
                </div>
                <div>
                    <label class="rh-label" asp-for="PorcentajeAvance"></label>
                    <input class="form-control rh-input" asp-for="PorcentajeAvance" type="number" min="0" max="100" />
                </div>
                <div>
                    <label class="rh-label" asp-for="Responsable"></label>
                    <input class="form-control rh-input" asp-for="Responsable" />
                </div>
                <div>
                    <label class="rh-label" asp-for="Prioridad"></label>
                    <select class="form-select rh-input" asp-for="Prioridad">
                        <option>Baja</option><option>Media</option><option>Alta</option><option>Crítica</option>
                    </select>
                </div>
                <div>
                    <label class="rh-label" asp-for="Riesgo"></label>
                    <select class="form-select rh-input" asp-for="Riesgo">
                        <option>Bajo</option><option>Medio</option><option>Alto</option>
                    </select>
                </div>
                <div>
                    <label class="rh-label" asp-for="EsHito"></label>
                    <select class="form-select rh-input" asp-for="EsHito">
                        <option value="false">No</option>
                        <option value="true">Sí</option>
                    </select>
                </div>
                <div class="rh-grid-full">
                    <label class="rh-label" asp-for="Descripcion"></label>
                    <textarea class="form-control rh-input" asp-for="Descripcion" rows="4"></textarea>
                </div>
            </div>

            <div class="rh-actions">
                <button class="rh-btn" type="submit">Guardar cambios</button>
                <a class="rh-btn rh-btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
