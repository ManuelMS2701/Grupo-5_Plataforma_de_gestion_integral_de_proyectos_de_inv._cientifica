@model ResearchHub.Models.Publicacion
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Crear publicacion";
}

<div class="rh-form-wrap">
    <h1 class="rh-form-title">Crear publicacion</h1>
    <p class="rh-form-sub">Registra articulos y salidas cientificas por proyecto.</p>

    <div class="rh-card">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="rh-grid">
                <div class="rh-grid-full">
                    <label class="rh-label" asp-for="Titulo"></label>
                    <input class="form-control rh-input" asp-for="Titulo" />
                    <span class="text-danger" asp-validation-for="Titulo"></span>
                </div>

                <div>
                    <label class="rh-label" asp-for="Revista"></label>
                    <input class="form-control rh-input" asp-for="Revista" />
                </div>

                <div>
                    <label class="rh-label" asp-for="DOI"></label>
                    <input class="form-control rh-input" asp-for="DOI" />
                </div>

                <div>
                    <label class="rh-label" asp-for="FechaPublicacion"></label>
                    <input class="form-control rh-input" asp-for="FechaPublicacion" type="date" />
                </div>

                <div>
                    <label class="rh-label">Proyecto</label>
                    <select class="form-select rh-input" asp-for="IdProyecto" asp-items="@(ViewData["IdProyecto"] as SelectList)"></select>
                </div>

                <div class="rh-grid-full">
                    <label class="rh-label" asp-for="Resumen"></label>
                    <textarea class="form-control rh-input" asp-for="Resumen" rows="4"></textarea>
                </div>
            </div>

            <div class="rh-actions">
                <button class="rh-btn" type="submit">Guardar</button>
                <a class="rh-btn rh-btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
