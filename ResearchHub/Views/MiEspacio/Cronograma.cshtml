@model IEnumerable<ResearchHub.Models.Cronograma>

@{
    ViewData["Title"] = "Mi cronograma";
}

<div class="rh-list-wrap">
    <div class="rh-list-header">
        <div>
            <h1 class="rh-list-title"><i class="bi bi-calendar-week"></i> Mi cronograma</h1>
            <p class="rh-meta">Hitos, dependencias y avance de tus proyectos.</p>
        </div>
        <a class="rh-btn rh-btn-secondary" asp-action="Index">Volver a mi espacio</a>
    </div>
    <div class="rh-table">
        <table class="table">
            <thead><tr><th>Fase</th><th>Proyecto</th><th>Estado</th><th>Avance</th><th>Dependencia</th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.NombreFase</td>
                    <td>@item.Proyecto?.Titulo</td>
                    <td><span class="rh-pill">@item.Estado</span></td>
                    <td>@item.PorcentajeAvance%</td>
                    <td>@item.Dependencia?.NombreFase</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
