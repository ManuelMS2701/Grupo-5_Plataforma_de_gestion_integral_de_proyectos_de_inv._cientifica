@model ResearchHub.Models.LoginViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Iniciar Sesion";
}

<div class="rh-auth-wrap">
    <a class="rh-brand" asp-controller="Account" asp-action="Login">ResearchHub</a>
    <h1 class="rh-auth-title">Iniciar Sesion</h1>
    <p class="rh-auth-sub">Accede a tu cuenta de ResearchHub.</p>

    <div class="rh-card">
        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="rh-label" asp-for="Email"></label>
                <input class="form-control rh-input" asp-for="Email" type="email" />
                <span class="text-danger" asp-validation-for="Email"></span>
            </div>

            <div class="mb-3">
                <label class="rh-label" asp-for="Password"></label>
                <input class="form-control rh-input" asp-for="Password" type="password" />
                <span class="text-danger" asp-validation-for="Password"></span>
            </div>

            <div class="form-check">
                <input class="form-check-input" asp-for="RememberMe" />
                <label class="form-check-label" asp-for="RememberMe">Recordarme</label>
            </div>

            <div class="rh-actions">
                <button class="rh-btn" type="submit">Entrar</button>
                <a class="rh-link" asp-action="Register">Crear cuenta</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
