@model ResearchHub.Models.RegisterViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Crear Cuenta";
}

<div class="rh-auth-wrap">
    <a class="rh-brand" asp-controller="Account" asp-action="Login">ResearchHub</a>
    <h1 class="rh-auth-title">Crear cuenta</h1>
    <p class="rh-auth-sub">Registra tu usuario para comenzar.</p>

    <div class="rh-card">
        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="rh-label" asp-for="NombreCompleto"></label>
                <input class="form-control rh-input" asp-for="NombreCompleto" />
                <span class="text-danger" asp-validation-for="NombreCompleto"></span>
            </div>

            <div class="mb-3">
                <label class="rh-label" asp-for="NombreUsuario"></label>
                <input class="form-control rh-input" asp-for="NombreUsuario" />
                <span class="text-danger" asp-validation-for="NombreUsuario"></span>
            </div>

            <div class="mb-3">
                <label class="rh-label" asp-for="Email"></label>
                <input class="form-control rh-input" asp-for="Email" type="email" />
                <span class="text-danger" asp-validation-for="Email"></span>
            </div>

            <div class="mb-3">
                <label class="rh-label" asp-for="IdRol"></label>
                <select class="form-select rh-input" asp-for="IdRol" asp-items="@(ViewData["Roles"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList)"></select>
                <span class="text-danger" asp-validation-for="IdRol"></span>
            </div>

            <div class="mb-3">
                <label class="rh-label" asp-for="Password"></label>
                <input class="form-control rh-input" asp-for="Password" type="password" />
                <span class="text-danger" asp-validation-for="Password"></span>
            </div>

            <div class="mb-3">
                <label class="rh-label" asp-for="ConfirmPassword"></label>
                <input class="form-control rh-input" asp-for="ConfirmPassword" type="password" />
                <span class="text-danger" asp-validation-for="ConfirmPassword"></span>
            </div>

            <div class="rh-actions">
                <button class="rh-btn" type="submit">Crear cuenta</button>
                <a class="rh-link" asp-action="Login">Ya tengo cuenta</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
