@model ResearchHub.Models.RolSistema

@{
    ViewData["Title"] = "Editar rol";
}

<div class="rh-form-wrap">
    <h1 class="rh-form-title"><i class="bi bi-pencil-square"></i> Editar rol</h1>
    <p class="rh-form-sub">Ajusta nombre, descripción y estado.</p>

    <div class="rh-card">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdRol" />
            <div class="rh-grid">
                <div>
                    <label class="rh-label" asp-for="Nombre"></label>
                    <input class="form-control rh-input" asp-for="Nombre" />
                    <span class="text-danger" asp-validation-for="Nombre"></span>
                </div>
                <div>
                    <label class="rh-label" asp-for="Activo"></label>
                    <select class="form-select rh-input" asp-for="Activo">
                        <option value="true">Activo</option>
                        <option value="false">Inactivo</option>
                    </select>
                </div>
                <div class="rh-grid-full">
                    <label class="rh-label" asp-for="Descripcion"></label>
                    <textarea class="form-control rh-input" asp-for="Descripcion" rows="4"></textarea>
                </div>
            </div>
            <div class="rh-actions">
                <button class="rh-btn" type="submit"><i class="bi bi-floppy"></i> Guardar cambios</button>
                <a class="rh-btn rh-btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>
