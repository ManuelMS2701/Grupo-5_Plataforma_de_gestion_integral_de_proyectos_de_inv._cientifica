@model ResearchHub.Models.RolSistema

@{
    ViewData["Title"] = "Eliminar rol";
}

<div class="rh-delete-wrap">
    <h1 class="rh-delete-title"><i class="bi bi-trash3"></i> Eliminar rol</h1>
    <p class="rh-warning">Esta acción elimina el rol si no tiene usuarios vinculados.</p>

    <div class="rh-card">
        <div class="rh-field">
            <span class="rh-field-label">Rol</span>
            <span class="rh-field-value">@Model.Nombre</span>
        </div>
        <div class="rh-field">
            <span class="rh-field-label">Descripción</span>
            <span class="rh-field-value">@Model.Descripcion</span>
        </div>

        <form asp-action="Delete" method="post" class="rh-actions">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdRol" />
            <button class="rh-btn rh-btn-danger" type="submit"><i class="bi bi-trash3"></i> Eliminar</button>
            <a class="rh-btn rh-btn-secondary" asp-action="Index">Cancelar</a>
        </form>
    </div>
</div>
