@{
    ViewData["Title"] = "ResearchHub";
}

<style>
    .rh-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 56px 20px 80px;
        font-family: "Space Grotesk", system-ui, sans-serif;
    }

    .rh-hero {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 28px;
        align-items: center;
        margin-bottom: 36px;
    }

    .rh-title {
        font-family: "Fraunces", serif;
        font-size: clamp(2.3rem, 4vw, 3.6rem);
        line-height: 1.05;
        margin: 0 0 12px;
        letter-spacing: -0.6px;
    }

    .rh-subtitle {
        color: #64748b;
        font-size: 1.05rem;
        margin: 0 0 20px;
        max-width: 56ch;
    }

    .rh-cta {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: linear-gradient(90deg, #5b8df6, #53c58a);
        color: #fff;
        padding: 12px 18px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        box-shadow: 0 10px 26px rgba(91, 141, 246, 0.22);
    }

    .rh-cta:hover {
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 14px 30px rgba(83, 197, 138, 0.22);
    }

    .rh-card {
        background: #ffffff;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 14px 30px rgba(15, 23, 42, 0.08);
    }

    .rh-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 16px;
    }

    .rh-chip {
        background: #eef3ff;
        color: #2b5bb5;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 600;
        font-size: 0.85rem;
        border: 1px solid rgba(43, 91, 181, 0.15);
    }

    .rh-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-top: 12px;
    }

    .rh-stat {
        background: #f8fafc;
        border-radius: 12px;
        padding: 14px;
        border: 1px dashed rgba(15, 23, 42, 0.1);
    }

    .rh-stat h4 {
        margin: 0 0 6px;
        font-size: 0.9rem;
        color: #64748b;
        font-weight: 500;
    }

    .rh-stat p {
        margin: 0;
        font-size: 1.3rem;
        font-weight: 600;
        color: #0f172a;
    }

    .rh-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-top: 18px;
    }

    .rh-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        background: #eef8ff;
        color: #2b5bb5;
        border: 1px solid rgba(43, 91, 181, 0.15);
        padding: 6px 10px;
        border-radius: 999px;
        font-weight: 600;
    }

    .rh-section-title {
        font-family: "Fraunces", serif;
        margin: 30px 0 12px;
        font-size: 1.7rem;
    }

    .rh-list {
        display: grid;
        gap: 12px;
    }

    .rh-item {
        background: #ffffff;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 14px;
        padding: 14px 16px;
        display: grid;
        gap: 6px;
    }

    .rh-item h5 {
        margin: 0;
        font-size: 1rem;
    }

    .rh-item p {
        margin: 0;
        color: #64748b;
        font-size: 0.95rem;
    }

    .rh-footer-note {
        margin-top: 30px;
        color: #64748b;
        font-size: 0.9rem;
        text-align: center;
    }

    @@media (max-width: 900px) {
        .rh-hero { grid-template-columns: 1fr; }
        .rh-grid { grid-template-columns: 1fr; }
        .rh-stats { grid-template-columns: 1fr; }
        .rh-card-header { flex-direction: column; align-items: flex-start; }
    }
</style>

<div class="rh-wrap">
    <div class="rh-hero">
        <div>
            <span class="rh-pill">ResearchHub · Plataforma de Investigación</span>
            <h1 class="rh-title">Organiza proyectos, experimentos y resultados con claridad científica.</h1>
            <p class="rh-subtitle">
                Centraliza investigadores, protocolos y datos en un flujo único. Un tablero limpio para
                controlar fases, validar análisis y publicar con trazabilidad.
            </p>
            <a class="rh-cta" href="/Proyectos">Explorar proyectos</a>
        </div>

        <div class="rh-card">
            <div class="rh-card-header">
                <h3 class="rh-section-title" style="margin:0;">Resumen rápido</h3>
                <span class="rh-chip">Estado general</span>
            </div>
            <div class="rh-stats">
                <div class="rh-stat">
                    <h4>Proyectos activos</h4>
                    <p>12</p>
                </div>
                <div class="rh-stat">
                    <h4>Experimentos</h4>
                    <p>48</p>
                </div>
                <div class="rh-stat">
                    <h4>Resultados</h4>
                    <p>326</p>
                </div>
            </div>
            <div class="rh-grid">
                <div class="rh-item">
                    <h5>Validaciones pendientes</h5>
                    <p>Revisiones de análisis en espera.</p>
                </div>
                <div class="rh-item">
                    <h5>Publicaciones</h5>
                    <p>Seguimiento de envíos y DOI.</p>
                </div>
                <div class="rh-item">
                    <h5>Repositorios</h5>
                    <p>Datos abiertos y trazables.</p>
                </div>
            </div>
        </div>
    </div>

    <h3 class="rh-section-title">Flujo de trabajo</h3>
    <div class="rh-list">
        <div class="rh-item">
            <h5>1. Planificación</h5>
            <p>Define cronogramas, asigna colaboradores y estructura la línea de investigación.</p>
        </div>
        <div class="rh-item">
            <h5>2. Ejecución</h5>
            <p>Controla experimentos, muestras, laboratorio y equipos asociados.</p>
        </div>
        <div class="rh-item">
            <h5>3. Resultados</h5>
            <p>Registra variables, analiza datos y valida hallazgos con evidencia.</p>
        </div>
    </div>

    <div class="rh-footer-note">
        Versión inicial · Base lista para crecer con tus módulos
    </div>
</div>
