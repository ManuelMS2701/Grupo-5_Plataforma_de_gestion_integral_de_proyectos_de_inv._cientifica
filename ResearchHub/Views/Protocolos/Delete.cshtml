@model ResearchHub.Models.Protocolo

@{
    ViewData["Title"] = "Eliminar protocolo";
    var tieneExperimentos = ViewData["TieneExperimentos"] as bool? ?? false;
    var deleteError = TempData["DeleteError"]?.ToString();
}

<style>
    .rh-delete-wrap {
        max-width: 920px;
        margin: 0 auto;
        padding: 40px 20px 70px;
        font-family: "Space Grotesk", system-ui, sans-serif;
    }

    .rh-delete-title {
        font-family: "Fraunces", serif;
        font-size: clamp(1.7rem, 3vw, 2.4rem);
        margin: 0 0 8px;
    }

    .rh-warning {
        color: #b91c1c;
        margin-bottom: 16px;
    }

    .rh-card {
        background: #ffffff;
        border: 1px solid rgba(15,23,42,0.08);
        border-radius: 16px;
        padding: 22px;
        box-shadow: 0 12px 24px rgba(15,23,42,0.06);
    }

    .rh-field {
        background: #f8fafc;
        border: 1px solid rgba(15,23,42,0.08);
        border-radius: 12px;
        padding: 12px 14px;
        margin-bottom: 10px;
    }

    .rh-label {
        font-size: 0.85rem;
        color: #64748b;
        margin-bottom: 6px;
        display: block;
    }

    .rh-value {
        font-weight: 600;
        color: #0f172a;
    }

    .rh-actions {
        display: flex;
        gap: 12px;
        margin-top: 18px;
    }

    .rh-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #ef4444;
        color: #fff;
        padding: 10px 14px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        border: none;
        box-shadow: 0 10px 24px rgba(239, 68, 68, 0.2);
    }

    .rh-btn-secondary {
        background: #e2e8f0;
        color: #0f172a;
        box-shadow: none;
    }

    .rh-alert {
        border: 1px solid rgba(239, 68, 68, 0.28);
        background: #fef2f2;
        color: #b91c1c;
        border-radius: 12px;
        padding: 10px 12px;
        margin-bottom: 12px;
    }
</style>

<div class="rh-delete-wrap">
    <h1 class="rh-delete-title">Eliminar protocolo</h1>
    <p class="rh-warning">Esta accion no se puede deshacer.</p>

    <div class="rh-card">
        @if (!string.IsNullOrWhiteSpace(deleteError))
        {
            <div class="rh-alert">@deleteError</div>
        }
        else if (tieneExperimentos)
        {
            <div class="rh-alert">No puedes eliminar este protocolo porque tiene experimentos asociados.</div>
        }

        <div class="rh-field">
            <span class="rh-label">Nombre</span>
            <span class="rh-value">@Model.Nombre</span>
        </div>
        <div class="rh-field">
            <span class="rh-label">Version</span>
            <span class="rh-value">@Model.Version</span>
        </div>
        <div class="rh-field">
            <span class="rh-label">Estado</span>
            <span class="rh-value">@(Model.Activo ? "Activo" : "Inactivo")</span>
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdProtocolo" />
            <div class="rh-actions">
                <button class="rh-btn" type="submit" @(tieneExperimentos ? "disabled" : null)>Eliminar</button>
                <a class="rh-btn rh-btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>
