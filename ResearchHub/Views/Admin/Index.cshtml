@{
    ViewData["Title"] = "Panel administrativo";
}

<style>
    .admin-shell {
        max-width: 1200px;
        margin: 0 auto;
        padding: 16px 4px 30px;
        font-family: "Space Grotesk", system-ui, sans-serif;
    }

    .admin-header {
        display: grid;
        gap: 8px;
        margin-bottom: 16px;
    }

    .admin-title {
        font-family: "Fraunces", serif;
        font-size: clamp(2rem, 3.5vw, 2.8rem);
        margin: 0;
        color: #0f172a;
    }

    .admin-subtitle {
        color: #64748b;
        margin: 0;
    }

    .admin-kpi {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin-bottom: 14px;
    }

    .kpi-card {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 14px;
        background: #fff;
        padding: 12px;
    }

    .kpi-card strong {
        display: block;
        font-size: 1.3rem;
        color: #0f172a;
    }

    .kpi-card span {
        color: #64748b;
    }

    .bench-title {
        font-family: "Fraunces", serif;
        margin: 18px 0 10px;
        color: #0f172a;
        font-size: 1.35rem;
    }

    .bench-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 16px;
    }

    .bench-card {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 12px;
        background: #fff;
        padding: 12px;
    }

    .bench-card h3 {
        margin: 0 0 6px;
        font-size: 0.95rem;
        color: #0f172a;
    }

    .bench-card p {
        margin: 0;
        color: #64748b;
        font-size: 0.86rem;
    }

    .admin-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
    }

    .admin-card {
        display: grid;
        gap: 10px;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 14px;
        background: #fff;
        padding: 14px;
        box-shadow: 0 12px 24px rgba(15, 23, 42, 0.06);
    }

    .admin-card h3 {
        margin: 0;
        font-size: 1.06rem;
        color: #0f172a;
    }

    .admin-card p {
        margin: 0;
        color: #64748b;
        font-size: 0.93rem;
    }

    .estado {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 4px 9px;
        font-size: 0.78rem;
        font-weight: 700;
        width: fit-content;
    }

    .ok {
        color: #166534;
        background: #dcfce7;
        border: 1px solid #bbf7d0;
    }

    .plan {
        color: #9a3412;
        background: #ffedd5;
        border: 1px solid #fed7aa;
    }

    .admin-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .admin-btn {
        border: 1px solid rgba(37, 99, 235, 0.2);
        color: #1d4ed8;
        background: #eff6ff;
        border-radius: 999px;
        padding: 7px 10px;
        font-size: 0.86rem;
        font-weight: 600;
        text-decoration: none;
    }

    .admin-btn:hover {
        background: #dbeafe;
    }

    @@media (max-width: 1120px) {
        .bench-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .admin-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 720px) {
        .admin-kpi {
            grid-template-columns: 1fr;
        }

        .bench-grid,
        .admin-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="admin-shell">
    <header class="admin-header">
        <h1 class="admin-title">Panel administrativo</h1>
        <p class="admin-subtitle">Gestion integral de investigacion con foco en trazabilidad, calidad y publicacion cientifica.</p>
    </header>



    <section class="admin-grid">
        <article class="admin-card">
            <h3>Investigador</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Perfil cientifico, ORCID, especialidad y vinculacion institucional.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Investigadores" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Investigador">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>Proyecto</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Centro de control del ciclo cientifico y eje para los demas modulos.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Proyectos" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Proyecto">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>LineaInvestigacion</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Clasificacion tematica y gobierno cientifico por linea activa.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="LineasInvestigacion" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="LineaInvestigacion">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>Institucion</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Gestion institucional de adscripcion y cooperacion de investigacion.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Instituciones" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Institucion">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>Experimento</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Ejecucion experimental con proyecto, protocolo y laboratorio asociado.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Experimentos" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Experimento">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>Muestra</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Registro de muestra con proyecto, origen, condicion y fecha de recoleccion.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Muestras" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Muestra">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>Laboratorio</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Capacidad, agenda de ocupacion y conflicto de recursos.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Laboratorios" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Laboratorio">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>EquipoLaboratorio</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Mantenimiento, calibracion y evidencia tecnica por equipo.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="EquiposLaboratorio" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="EquipoLaboratorio">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>Protocolo</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Versionado de protocolos, estado de vigencia y control de uso.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Protocolos" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Protocolo">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>Variable</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Estandar de unidades, rangos y alertas de calidad del dato.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Variables" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Variable">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>Resultado</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Datos experimentales vinculados a variable y observaciones tecnicas.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Resultados" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Resultado">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>Analisis</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Metodologia estandar, revision y trazabilidad de conclusiones.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Analisis" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Analisis">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>Publicacion</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Pipeline editorial con DOI y enlace a resultados/datasets.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Publicaciones" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Publicacion">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>RepositorioDatos</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Licencias, version, embargo y checklist FAIR antes de publicar.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="RepositoriosDatos" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="RepositorioDatos">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>Colaborador</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Roles por entidad y vigencia de colaboracion por proyecto.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Colaboradores" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Colaborador">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>Cronograma</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Dependencias, ruta critica y alertas por vencimiento.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Cronogramas" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Cronograma">Roadmap</a>
            </div>
        </article>

        <article class="admin-card">
            <h3>Validacion</h3>
            <span class="estado ok">CRUD activo</span>
            <p>Aprobacion formal con evidencia y seguimiento por SLA.</p>
            <div class="admin-actions">
                <a class="admin-btn" asp-controller="Validaciones" asp-action="Index">Abrir</a>
                <a class="admin-btn" asp-controller="Gestion" asp-action="Entidad" asp-route-nombre="Validacion">Roadmap</a>
            </div>
        </article>
    </section>
</div>


