@model ResearchHub.Models.Colaborador
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Editar colaborador";
}

<div class="rh-form-wrap">
    <h1 class="rh-form-title">Editar colaborador</h1>
    <p class="rh-form-sub">Actualiza datos de contacto, rol y proyecto.</p>

    <div class="rh-card">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdColaborador" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="rh-grid">
                <div>
                    <label class="rh-label" asp-for="Nombre"></label>
                    <input class="form-control rh-input" asp-for="Nombre" />
                </div>
                <div>
                    <label class="rh-label" asp-for="Apellido"></label>
                    <input class="form-control rh-input" asp-for="Apellido" />
                </div>
                <div>
                    <label class="rh-label" asp-for="Email"></label>
                    <input class="form-control rh-input" asp-for="Email" />
                </div>
                <div>
                    <label class="rh-label" asp-for="Tipo"></label>
                    <input class="form-control rh-input" asp-for="Tipo" />
                </div>
                <div>
                    <label class="rh-label" asp-for="Rol"></label>
                    <input class="form-control rh-input" asp-for="Rol" />
                </div>
                <div>
                    <label class="rh-label">Proyecto</label>
                    <select class="form-select rh-input" asp-for="IdProyecto" asp-items="@(ViewData["IdProyecto"] as SelectList)"></select>
                </div>
            </div>

            <div class="rh-actions">
                <button class="rh-btn" type="submit">Guardar cambios</button>
                <a class="rh-btn rh-btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
