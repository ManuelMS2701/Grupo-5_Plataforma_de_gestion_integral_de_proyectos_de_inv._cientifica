@model ResearchHub.Models.SublineaInvestigacion
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Editar sublínea";
}

<div class="rh-form-wrap">
    <h1 class="rh-form-title">Editar sublínea</h1>
    <p class="rh-form-sub">Ajusta la relación con línea y su estado.</p>

    <div class="rh-card">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdSublinea" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="rh-grid">
                <div>
                    <label class="rh-label">Línea principal</label>
                    <select class="form-select rh-input" asp-for="IdLinea" asp-items="@(ViewData["IdLinea"] as SelectList)"></select>
                </div>
                <div>
                    <label class="rh-label" asp-for="Nombre"></label>
                    <input class="form-control rh-input" asp-for="Nombre" />
                </div>
                <div class="rh-grid-full">
                    <label class="rh-label" asp-for="Descripcion"></label>
                    <textarea class="form-control rh-input" asp-for="Descripcion" rows="3"></textarea>
                </div>
                <div>
                    <label class="rh-label" asp-for="Activa"></label>
                    <select class="form-select rh-input" asp-for="Activa">
                        <option value="true">Sí</option>
                        <option value="false">No</option>
                    </select>
                </div>
            </div>

            <div class="rh-actions">
                <button class="rh-btn" type="submit">Guardar cambios</button>
                <a class="rh-btn rh-btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
