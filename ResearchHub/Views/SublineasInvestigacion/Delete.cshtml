@model ResearchHub.Models.SublineaInvestigacion
@{
    ViewData["Title"] = "Eliminar sublínea";
}

<div class="rh-delete-wrap">
    <h1 class="rh-delete-title">Eliminar sublínea</h1>
    <p class="rh-warning">Esta acción no se puede deshacer.</p>

    <div class="rh-card">
        <div class="rh-field">
            <span class="rh-field-label">Línea principal</span>
            <span class="rh-field-value">@Model.LineaInvestigacion?.Nombre</span>
        </div>
        <div class="rh-field">
            <span class="rh-field-label">Nombre</span>
            <span class="rh-field-value">@Model.Nombre</span>
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdSublinea" />
            <div class="rh-actions">
                <button class="rh-btn rh-btn-danger" type="submit">Eliminar</button>
                <a class="rh-btn rh-btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>
