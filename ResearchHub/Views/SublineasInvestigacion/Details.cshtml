@model ResearchHub.Models.SublineaInvestigacion
@{
    ViewData["Title"] = "Detalle de sublínea";
}

<div class="rh-details-wrap">
    <h1 class="rh-details-title">Detalle de sublínea</h1>

    <div class="rh-card">
        <div class="rh-grid">
            <div class="rh-field">
                <span class="rh-field-label">Línea principal</span>
                <span class="rh-field-value">@Model.LineaInvestigacion?.Nombre</span>
            </div>
            <div class="rh-field">
                <span class="rh-field-label">Nombre</span>
                <span class="rh-field-value">@Model.Nombre</span>
            </div>
            <div class="rh-field">
                <span class="rh-field-label">Activa</span>
                <span class="rh-field-value">@(Model.Activa ? "Sí" : "No")</span>
            </div>
            <div class="rh-field rh-grid-full">
                <span class="rh-field-label">Descripción</span>
                <span class="rh-field-value">@Model.Descripcion</span>
            </div>
        </div>

        <div class="rh-actions">
            <a class="rh-btn" asp-action="Edit" asp-route-id="@Model.IdSublinea">Editar</a>
            <a class="rh-btn rh-btn-secondary" asp-action="Index">Volver</a>
        </div>
    </div>
</div>
