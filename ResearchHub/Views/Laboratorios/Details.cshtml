@model ResearchHub.Models.Laboratorio

@{
    ViewData["Title"] = "Detalle del laboratorio";
}

<style>
    .rh-details-wrap {
        max-width: 920px;
        margin: 0 auto;
        padding: 40px 20px 70px;
        font-family: "Space Grotesk", system-ui, sans-serif;
    }

    .rh-details-title {
        font-family: "Fraunces", serif;
        font-size: clamp(1.7rem, 3vw, 2.4rem);
        margin: 0 0 8px;
    }

    .rh-card {
        background: #ffffff;
        border: 1px solid rgba(15,23,42,0.08);
        border-radius: 16px;
        padding: 22px;
        box-shadow: 0 12px 24px rgba(15,23,42,0.06);
    }

    .rh-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 14px;
    }

    .rh-field {
        background: #f8fafc;
        border: 1px solid rgba(15,23,42,0.08);
        border-radius: 12px;
        padding: 12px 14px;
    }

    .rh-label {
        font-size: 0.85rem;
        color: #64748b;
        margin-bottom: 6px;
        display: block;
    }

    .rh-value {
        font-weight: 600;
        color: #0f172a;
    }

    .rh-actions {
        display: flex;
        gap: 12px;
        margin-top: 18px;
    }

    .rh-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #5b8df6;
        color: #fff;
        padding: 10px 14px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        border: none;
        box-shadow: 0 10px 24px rgba(91, 141, 246, 0.2);
    }

    .rh-btn-secondary {
        background: #e2e8f0;
        color: #0f172a;
        box-shadow: none;
    }

    @@media (max-width: 900px) {
        .rh-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="rh-details-wrap">
    <h1 class="rh-details-title">Detalle del laboratorio</h1>

    <div class="rh-card">
        <div class="rh-grid">
            <div class="rh-field">
                <span class="rh-label">Nombre</span>
                <span class="rh-value">@Model.Nombre</span>
            </div>
            <div class="rh-field">
                <span class="rh-label">Ubicacion</span>
                <span class="rh-value">@Model.Ubicacion</span>
            </div>
            <div class="rh-field">
                <span class="rh-label">Capacidad</span>
                <span class="rh-value">@Model.Capacidad</span>
            </div>
            <div class="rh-field">
                <span class="rh-label">Responsable</span>
                <span class="rh-value">@Model.Responsable</span>
            </div>
            <div class="rh-field">
                <span class="rh-label">Estado</span>
                <span class="rh-value">@(Model.Activo ? "Activo" : "Inactivo")</span>
            </div>
        </div>

        <div class="rh-actions">
            <a class="rh-btn" asp-action="Edit" asp-route-id="@Model.IdLaboratorio">Editar</a>
            <a class="rh-btn rh-btn-secondary" asp-action="Index">Volver</a>
        </div>
    </div>
</div>
