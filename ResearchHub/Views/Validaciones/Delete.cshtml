@model ResearchHub.Models.Validacion
@{
    ViewData["Title"] = "Eliminar validacion";
}

<div class="rh-delete-wrap">
    <h1 class="rh-delete-title">Eliminar validacion</h1>
    <p class="rh-warning">Esta accion no se puede deshacer.</p>

    <div class="rh-card">
        <div class="rh-field">
            <span class="rh-field-label">Fecha</span>
            <span class="rh-field-value">@(Model.Fecha?.ToString("yyyy-MM-dd") ?? "-")</span>
        </div>
        <div class="rh-field">
            <span class="rh-field-label">Resultado</span>
            <span class="rh-field-value">@Model.Resultado</span>
        </div>
        <div class="rh-field">
            <span class="rh-field-label">Analisis</span>
            <span class="rh-field-value">@Model.IdAnalisis</span>
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdValidacion" />
            <div class="rh-actions">
                <button class="rh-btn rh-btn-danger" type="submit">Eliminar</button>
                <a class="rh-btn rh-btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>
