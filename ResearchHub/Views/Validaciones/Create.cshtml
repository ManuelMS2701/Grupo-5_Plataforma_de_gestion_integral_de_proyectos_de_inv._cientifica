@model ResearchHub.Models.Validacion
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Crear validacion";
}

<div class="rh-form-wrap">
    <h1 class="rh-form-title">Crear validacion</h1>
    <p class="rh-form-sub">Registra revision de calidad sobre un analisis.</p>

    <div class="rh-card">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="rh-grid">
                <div>
                    <label class="rh-label" asp-for="Fecha"></label>
                    <input class="form-control rh-input" asp-for="Fecha" type="date" />
                </div>
                <div>
                    <label class="rh-label" asp-for="Resultado"></label>
                    <input class="form-control rh-input" asp-for="Resultado" />
                </div>
                <div>
                    <label class="rh-label" asp-for="Validador"></label>
                    <input class="form-control rh-input" asp-for="Validador" />
                </div>
                <div>
                    <label class="rh-label">Analisis</label>
                    <select class="form-select rh-input" asp-for="IdAnalisis" asp-items="@(ViewData["IdAnalisis"] as SelectList)"></select>
                </div>
                <div class="rh-grid-full">
                    <label class="rh-label" asp-for="Observaciones"></label>
                    <textarea class="form-control rh-input" asp-for="Observaciones" rows="4"></textarea>
                </div>
            </div>

            <div class="rh-actions">
                <button class="rh-btn" type="submit">Guardar</button>
                <a class="rh-btn rh-btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
