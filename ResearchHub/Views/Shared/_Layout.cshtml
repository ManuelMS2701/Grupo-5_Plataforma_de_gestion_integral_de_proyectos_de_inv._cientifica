@using ResearchHub.Models
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
    var isAdmin = User?.IsInRole(Roles.Administrador) == true;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isInvestigador = User?.IsInRole(Roles.Investigador) == true;
    var isInvestigadorPrincipal = User?.IsInRole(Roles.InvestigadorPrincipal) == true;
    var isRevisor = User?.IsInRole(Roles.RevisorCientifico) == true;
    var isTecnico = User?.IsInRole(Roles.TecnicoLaboratorio) == true;
    var isAnalista = User?.IsInRole(Roles.AnalistaDatos) == true;
    var isColaboradorExterno = User?.IsInRole(Roles.ColaboradorExterno) == true;
    var puedeGestionarTrabajo = isInvestigador || isInvestigadorPrincipal || isTecnico || isAnalista;
    var puedeCrearBitacora = !isColaboradorExterno;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ResearchHub</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/crud.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ResearchHub.styles.css" asp-append-version="true" />
    <style>
        :root {
            --nav-bg: #f9fbff;
            --nav-soft: #eff4fb;
            --nav-text: #1e293b;
            --nav-muted: #64748b;
            --nav-active: #e1ecfb;
            --nav-accent: linear-gradient(135deg, #0ea5e9, #22c55e);
            --ink: #0f172a;
            --muted: #64748b;
            --paper: #f6f8fc;
            --ring: rgba(15, 23, 42, 0.08);
        }

        body {
            margin: 0;
            font-family: "Space Grotesk", system-ui, sans-serif;
            background: radial-gradient(850px 350px at 100% -5%, #e9f1ff 0%, transparent 62%), var(--paper);
            color: var(--ink);
        }

        .app-shell {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 300px 1fr;
        }

        .side {
            background: var(--nav-bg);
            border-right: 1px solid var(--ring);
            padding: 18px 12px;
            display: grid;
            grid-template-rows: auto 1fr auto;
            gap: 14px;
            position: sticky;
            top: 0;
            height: 100vh;
        }

        .side nav {
            overflow-y: auto;
            padding-right: 4px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: #0f172a;
            padding: 8px 8px 12px;
            border-bottom: 1px solid var(--ring);
        }

        .brand img {
            width: 54px;
            height: 54px;
            object-fit: contain;
            border-radius: 10px;
            background: #fff;
            border: 1px solid rgba(15, 23, 42, 0.08);
            padding: 3px;
        }

        .brand span {
            font-family: "Fraunces", serif;
            font-size: 1.25rem;
            letter-spacing: -0.3px;
        }

        .brand-mark {
            width: 54px;
            height: 54px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 14px;
            background: var(--nav-accent);
            color: #fff;
            font-size: 1.4rem;
            box-shadow: 0 14px 28px rgba(14, 165, 233, 0.18);
        }

        .menu-group {
            margin-bottom: 12px;
        }

        .menu-title {
            color: #475569;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.09em;
            margin: 0 0 7px 10px;
            font-weight: 700;
        }

        .menu-link {
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--nav-text);
            text-decoration: none;
            padding: 9px 11px;
            margin-bottom: 5px;
            border-radius: 10px;
            border: 1px solid transparent;
            font-weight: 500;
            font-size: 0.93rem;
        }

        .menu-link:hover {
            background: var(--nav-soft);
            border-color: rgba(148, 163, 184, 0.22);
            color: #0f172a;
        }

        .menu-link.active {
            background: var(--nav-active);
            border-color: rgba(96, 165, 250, 0.2);
            color: #0f172a;
        }

        .menu-link i {
            width: 18px;
            text-align: center;
            color: #2563eb;
        }

        .side-user {
            border-top: 1px solid var(--ring);
            padding-top: 12px;
            font-size: 0.9rem;
            color: var(--nav-muted);
        }

        .side-btn {
            width: 100%;
            margin-top: 10px;
            border: 1px solid rgba(15, 23, 42, 0.15);
            background: #fff;
            color: #1e293b;
            border-radius: 10px;
            padding: 8px 10px;
            font-weight: 600;
        }

        .main {
            display: grid;
            grid-template-rows: 1fr auto;
            min-width: 0;
        }

        .content {
            padding: 20px 24px 28px;
        }

        .footer {
            border-top: 1px solid var(--ring);
            color: var(--muted);
            font-size: 0.9rem;
            background: rgba(255, 255, 255, 0.75);
            padding: 11px 24px;
        }

        .mobile-top {
            display: none;
        }

        @@media (max-width: 1060px) {
            .app-shell {
                grid-template-columns: 1fr;
            }

            .side {
                display: none;
            }

            .mobile-top {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 8px;
                padding: 10px 14px;
                border-bottom: 1px solid var(--ring);
                background: #fff;
                position: sticky;
                top: 0;
                z-index: 10;
            }

            .mobile-top a {
                text-decoration: none;
                color: #1e293b;
                font-weight: 600;
            }
        }
    </style>
</head>
<body>
    <div class="mobile-top">
        <a asp-controller="Home" asp-action="Index">ResearchHub</a>
        @if (isAuthenticated)
        {
            <span>@User.Identity?.Name</span>
        }
    </div>

    <div class="app-shell">
        <aside class="side">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <span class="brand-mark"><i class="bi bi-flask"></i></span>
                <span>ResearchHub</span>
            </a>

            <nav>
                <div class="menu-group">
                    <p class="menu-title">General</p>
                    <a class="menu-link @(controller == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door"></i> Inicio</a>
                    <a class="menu-link @(controller == "MiEspacio" ? "active" : "")" asp-controller="MiEspacio" asp-action="Index"><i class="bi bi-stars"></i> Mi espacio</a>
                    <a class="menu-link @(controller == "Proyectos" ? "active" : "")" asp-controller="Proyectos" asp-action="Index"><i class="bi bi-kanban"></i> Proyectos</a>
                    <a class="menu-link @(controller == "Busqueda" ? "active" : "")" asp-controller="Busqueda" asp-action="Index"><i class="bi bi-search"></i> Busqueda global</a>
                </div>

                @if (isAdmin)
                {
                    <div class="menu-group">
                        <p class="menu-title">Ejecucion cientifica</p>
                        <a class="menu-link @(controller == "Experimentos" ? "active" : "")" asp-controller="Experimentos" asp-action="Index"><i class="bi bi-bezier2"></i> Experimentos</a>
                        <a class="menu-link @(controller == "Muestras" ? "active" : "")" asp-controller="Muestras" asp-action="Index"><i class="bi bi-droplet"></i> Muestras</a>
                        <a class="menu-link @(controller == "Laboratorios" ? "active" : "")" asp-controller="Laboratorios" asp-action="Index"><i class="bi bi-building"></i> Laboratorios</a>
                        <a class="menu-link @(controller == "EquiposLaboratorio" ? "active" : "")" asp-controller="EquiposLaboratorio" asp-action="Index"><i class="bi bi-cpu"></i> Equipos</a>
                        <a class="menu-link @(controller == "Protocolos" ? "active" : "")" asp-controller="Protocolos" asp-action="Index"><i class="bi bi-journal-medical"></i> Protocolos</a>
                    </div>

                    <div class="menu-group">
                        <p class="menu-title">Datos y calidad</p>
                        <a class="menu-link @(controller == "Variables" ? "active" : "")" asp-controller="Variables" asp-action="Index"><i class="bi bi-sliders"></i> Variables</a>
                        <a class="menu-link @(controller == "Resultados" ? "active" : "")" asp-controller="Resultados" asp-action="Index"><i class="bi bi-clipboard-data"></i> Resultados</a>
                        <a class="menu-link @(controller == "Analisis" ? "active" : "")" asp-controller="Analisis" asp-action="Index"><i class="bi bi-graph-up-arrow"></i> Analisis</a>
                        <a class="menu-link @(controller == "Validaciones" ? "active" : "")" asp-controller="Validaciones" asp-action="Index"><i class="bi bi-patch-check"></i> Validaciones</a>
                        <a class="menu-link @(controller == "RepositoriosDatos" ? "active" : "")" asp-controller="RepositoriosDatos" asp-action="Index"><i class="bi bi-database"></i> Repositorios</a>
                        <a class="menu-link @(controller == "Publicaciones" ? "active" : "")" asp-controller="Publicaciones" asp-action="Index"><i class="bi bi-journal-richtext"></i> Publicaciones</a>
                    </div>
                }
                else
                {
                    <div class="menu-group">
                        <p class="menu-title">Trabajo cientifico</p>
                        <a class="menu-link @(controller == "MiEspacio" && currentAction == "Experimentos" ? "active" : "")" asp-controller="MiEspacio" asp-action="Experimentos"><i class="bi bi-bezier2"></i> Experimentos</a>
                        <a class="menu-link @(controller == "MiEspacio" && currentAction == "Cronograma" ? "active" : "")" asp-controller="MiEspacio" asp-action="Cronograma"><i class="bi bi-calendar-week"></i> Cronograma</a>
                        @if (puedeGestionarTrabajo)
                        {
                            <a class="menu-link @(controller == "MiEspacio" && currentAction == "Tareas" ? "active" : "")" asp-controller="MiEspacio" asp-action="Tareas"><i class="bi bi-list-check"></i> Tareas</a>
                        }
                        @if (puedeCrearBitacora || isRevisor)
                        {
                            <a class="menu-link @(controller == "MiEspacio" && currentAction == "Bitacora" ? "active" : "")" asp-controller="MiEspacio" asp-action="Bitacora"><i class="bi bi-journal-bookmark"></i> Bitacora</a>
                        }
                        @if (isInvestigador || isInvestigadorPrincipal || isTecnico)
                        {
                            <a class="menu-link @(controller == "MiEspacio" && currentAction == "Muestras" ? "active" : "")" asp-controller="MiEspacio" asp-action="Muestras"><i class="bi bi-droplet"></i> Muestras</a>
                        }
                        @if (isInvestigador || isInvestigadorPrincipal || isAnalista || isRevisor || isColaboradorExterno)
                        {
                            <a class="menu-link @(controller == "MiEspacio" && currentAction == "Resultados" ? "active" : "")" asp-controller="MiEspacio" asp-action="Resultados"><i class="bi bi-clipboard-data"></i> Resultados</a>
                            <a class="menu-link @(controller == "MiEspacio" && currentAction == "Publicaciones" ? "active" : "")" asp-controller="MiEspacio" asp-action="Publicaciones"><i class="bi bi-journal-text"></i> Publicaciones</a>
                        }
                    </div>

                    @if (isInvestigadorPrincipal || isInvestigador)
                    {
                        <div class="menu-group">
                            <p class="menu-title">Impulso de proyectos</p>
                            <a class="menu-link @(controller == "Proyectos" && currentAction == "CreatePropio" ? "active" : "")" asp-controller="Proyectos" asp-action="CreatePropio"><i class="bi bi-lightbulb"></i> Proponer proyecto</a>
                            <a class="menu-link @(controller == "Proyectos" && Context.Request.Query["misProyectos"] == "true" ? "active" : "")" asp-controller="Proyectos" asp-action="Index" asp-route-misProyectos="true"><i class="bi bi-person-workspace"></i> Mis proyectos</a>
                        </div>
                    }

                    @if (isRevisor || isAnalista)
                    {
                        <div class="menu-group">
                            <p class="menu-title">Revision y evidencia</p>
                            <a class="menu-link @(controller == "Busqueda" ? "active" : "")" asp-controller="Busqueda" asp-action="Index"><i class="bi bi-search-heart"></i> Revisar resultados</a>
                        </div>
                    }
                }

                @if (isAdmin)
                {
                    <div class="menu-group">
                        <p class="menu-title">Administracion</p>
                        <a class="menu-link @(controller == "Admin" ? "active" : "")" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2"></i> Panel admin</a>
                        <a class="menu-link @(controller == "UsuariosSistema" ? "active" : "")" asp-controller="UsuariosSistema" asp-action="Index"><i class="bi bi-people"></i> Usuarios</a>
                        <a class="menu-link @(controller == "RolesSistema" ? "active" : "")" asp-controller="RolesSistema" asp-action="Index"><i class="bi bi-shield-lock"></i> Roles</a>
                        <a class="menu-link @(controller == "Instituciones" ? "active" : "")" asp-controller="Instituciones" asp-action="Index"><i class="bi bi-bank"></i> Instituciones</a>
                        <a class="menu-link @(controller == "Investigadores" ? "active" : "")" asp-controller="Investigadores" asp-action="Index"><i class="bi bi-person-badge"></i> Investigadores</a>
                        <a class="menu-link @(controller == "LineasInvestigacion" ? "active" : "")" asp-controller="LineasInvestigacion" asp-action="Index"><i class="bi bi-diagram-3"></i> Lineas de investigacion</a>
                        <a class="menu-link @(controller == "SublineasInvestigacion" ? "active" : "")" asp-controller="SublineasInvestigacion" asp-action="Index"><i class="bi bi-node-plus"></i> Sublineas</a>
                        <a class="menu-link @(controller == "Colaboradores" ? "active" : "")" asp-controller="Colaboradores" asp-action="Index"><i class="bi bi-people-fill"></i> Colaboradores</a>
                        <a class="menu-link @(controller == "Cronogramas" ? "active" : "")" asp-controller="Cronogramas" asp-action="Index"><i class="bi bi-calendar3"></i> Cronogramas</a>
                    </div>
                }
            </nav>

            <div class="side-user">
                @if (isAuthenticated)
                {
                    <div>Sesion: @User.Identity?.Name</div>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="side-btn"><i class="bi bi-box-arrow-right"></i> Cerrar sesion</button>
                    </form>
                }
                else
                {
                    <a class="menu-link" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right"></i> Iniciar sesion</a>
                }
            </div>
        </aside>

        <div class="main">
            <main class="content">
                @RenderBody()
            </main>
            <footer class="footer">
                &copy; 2026 - ResearchHub
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>











