@model IEnumerable<ResearchHub.Models.Resultado>

@{
    ViewData["Title"] = "Resultados";
}

<style>
    .rh-list-wrap {
        max-width: 1120px;
        margin: 0 auto;
        padding: 40px 20px 70px;
        font-family: "Space Grotesk", system-ui, sans-serif;
    }

    .rh-list-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
    }

    .rh-list-title {
        font-family: "Fraunces", serif;
        font-size: clamp(1.7rem, 3vw, 2.4rem);
        margin: 0;
    }

    .rh-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #5b8df6;
        color: #fff;
        padding: 10px 14px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        box-shadow: 0 10px 24px rgba(91, 141, 246, 0.2);
    }

    .rh-btn:hover { color: #fff; }

    .rh-table {
        background: #fff;
        border: 1px solid rgba(15,23,42,0.08);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 12px 24px rgba(15,23,42,0.06);
    }

    .rh-table table {
        width: 100%;
        margin: 0;
    }

    .rh-table thead {
        background: #f7f9fc;
        color: #475569;
        font-size: 0.9rem;
    }

    .rh-table th, .rh-table td {
        padding: 14px 16px;
        vertical-align: middle;
    }

    .rh-pill {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 999px;
        background: #eef3ff;
        color: #2b5bb5;
        font-weight: 600;
        font-size: 0.82rem;
        border: 1px solid rgba(43, 91, 181, 0.12);
    }

    .rh-actions a {
        margin-right: 8px;
        text-decoration: none;
        font-weight: 600;
        color: #1d4ed8;
    }

    .rh-actions a:hover { text-decoration: underline; }

    @@media (max-width: 980px) {
        .rh-list-header {
            flex-direction: column;
            align-items: flex-start;
        }
        .rh-table th:nth-child(4),
        .rh-table td:nth-child(4),
        .rh-table th:nth-child(5),
        .rh-table td:nth-child(5) {
            display: none;
        }
    }
</style>

<div class="rh-list-wrap">
    <div class="rh-list-header">
        <h1 class="rh-list-title">Resultados</h1>
        <a class="rh-btn" asp-controller="Resultados" asp-action="Create">Nuevo resultado</a>
    </div>

    <div class="rh-table">
        <table class="table">
            <thead>
                <tr>
                    <th>Fecha registro</th>
                    <th>Valor</th>
                    <th>Experimento</th>
                    <th>Variable</th>
                    <th>Observaciones</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="rh-pill">@item.FechaRegistro.ToString("yyyy-MM-dd")</span></td>
                    <td>@item.Valor</td>
                    <td>@item.Experimento?.Titulo</td>
                    <td>@item.Variable?.Nombre</td>
                    <td>@item.Observaciones</td>
                    <td class="rh-actions">
                        <a asp-action="Edit" asp-route-id="@item.IdResultado">Editar</a>
                        <a asp-action="Details" asp-route-id="@item.IdResultado">Detalles</a>
                        <a asp-action="Delete" asp-route-id="@item.IdResultado">Eliminar</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
