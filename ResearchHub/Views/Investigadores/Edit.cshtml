@model ResearchHub.Models.Investigador
@using ResearchHub.Models

@{
    ViewData["Title"] = "Editar investigador";
    var instituciones = ViewData["Instituciones"] as List<Institucion> ?? new List<Institucion>();
}

<style>
    .rh-form-wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 40px 20px 70px;
        font-family: "Space Grotesk", system-ui, sans-serif;
    }

    .rh-form-title {
        font-family: "Fraunces", serif;
        font-size: clamp(1.7rem, 3vw, 2.4rem);
        margin: 0 0 8px;
    }

    .rh-form-sub {
        color: #64748b;
        margin-bottom: 20px;
    }

    .rh-card {
        background: #ffffff;
        border: 1px solid rgba(15,23,42,0.08);
        border-radius: 16px;
        padding: 22px;
        box-shadow: 0 12px 24px rgba(15,23,42,0.06);
    }

    .rh-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    .rh-grid-full {
        grid-column: 1 / -1;
    }

    .rh-label {
        font-weight: 600;
        margin-bottom: 6px;
    }

    .rh-input {
        border-radius: 10px;
        border: 1px solid rgba(15,23,42,0.12);
        padding: 10px 12px;
    }

    .rh-actions {
        display: flex;
        gap: 12px;
        margin-top: 18px;
    }

    .rh-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #5b8df6;
        color: #fff;
        padding: 10px 14px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        border: none;
        box-shadow: 0 10px 24px rgba(91, 141, 246, 0.2);
    }

    .rh-btn-secondary {
        background: #e2e8f0;
        color: #0f172a;
        box-shadow: none;
    }

    @@media (max-width: 900px) {
        .rh-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="rh-form-wrap">
    <h1 class="rh-form-title">Editar investigador</h1>
    <p class="rh-form-sub">Actualiza los datos del investigador.</p>

    <div class="rh-card">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IdInvestigador" />

            <div class="rh-grid">
                <div>
                    <label class="rh-label" asp-for="Nombre"></label>
                    <input class="form-control rh-input" asp-for="Nombre" />
                    <span class="text-danger" asp-validation-for="Nombre"></span>
                </div>

                <div>
                    <label class="rh-label" asp-for="Apellido"></label>
                    <input class="form-control rh-input" asp-for="Apellido" />
                    <span class="text-danger" asp-validation-for="Apellido"></span>
                </div>

                <div>
                    <label class="rh-label" asp-for="Email"></label>
                    <input class="form-control rh-input" asp-for="Email" type="email" />
                    <span class="text-danger" asp-validation-for="Email"></span>
                </div>

                <div>
                    <label class="rh-label" asp-for="Telefono"></label>
                    <input class="form-control rh-input" asp-for="Telefono" />
                </div>

                <div>
                    <label class="rh-label" asp-for="Especialidad"></label>
                    <input class="form-control rh-input" asp-for="Especialidad" />
                </div>

                <div>
                    <label class="rh-label" asp-for="Orcid"></label>
                    <input class="form-control rh-input" asp-for="Orcid" />
                </div>

                <div>
                    <label class="rh-label">Institución</label>
                    <select class="form-select rh-input" asp-for="IdInstitucion">
                        @foreach (var inst in instituciones)
                        {
                            <option value="@inst.IdInstitucion" selected="@(inst.IdInstitucion == Model.IdInstitucion)">@inst.Nombre</option>
                        }
                    </select>
                </div>

                <div>
                    <label class="rh-label" asp-for="Activo"></label>
                    <select class="form-select rh-input" asp-for="Activo">
                        <option value="true" selected="@(Model.Activo)">Sí</option>
                        <option value="false" selected="@(!Model.Activo)">No</option>
                    </select>
                </div>
            </div>

            <div class="rh-actions">
                <button class="rh-btn" type="submit">Guardar cambios</button>
                <a class="rh-btn rh-btn-secondary" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>
