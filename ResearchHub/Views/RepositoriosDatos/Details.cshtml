@model ResearchHub.Models.RepositorioDatos
@{
    ViewData["Title"] = "Detalle de repositorio";
}

<div class="rh-details-wrap">
    <h1 class="rh-details-title">Detalle de repositorio de datos</h1>

    <div class="rh-card">
        <div class="rh-grid">
            <div class="rh-field">
                <span class="rh-field-label">Nombre</span>
                <span class="rh-field-value">@Model.Nombre</span>
            </div>
            <div class="rh-field">
                <span class="rh-field-label">Tipo</span>
                <span class="rh-field-value">@Model.Tipo</span>
            </div>
            <div class="rh-field rh-grid-full">
                <span class="rh-field-label">URL</span>
                <span class="rh-field-value">@Model.Url</span>
            </div>
            <div class="rh-field">
                <span class="rh-field-label">Fecha registro</span>
                <span class="rh-field-value">@(Model.FechaRegistro?.ToString("yyyy-MM-dd") ?? "-")</span>
            </div>
            <div class="rh-field">
                <span class="rh-field-label">Proyecto</span>
                <span class="rh-field-value">@Model.Proyecto?.Titulo</span>
            </div>
            <div class="rh-field rh-grid-full">
                <span class="rh-field-label">Descripcion</span>
                <span class="rh-field-value">@Model.Descripcion</span>
            </div>
        </div>

        <div class="rh-actions">
            <a class="rh-btn" asp-action="Edit" asp-route-id="@Model.IdRepositorio">Editar</a>
            <a class="rh-btn rh-btn-secondary" asp-action="Index">Volver</a>
        </div>
    </div>
</div>

