@model ResearchHub.Models.ProyectoHubViewModel

@{
    ViewData["Title"] = "Hub del proyecto";
}

<div class="rh-list-wrap">
    <div class="rh-list-header">
        <div>
            <h1 class="rh-list-title">Hub: @Model.Proyecto.Titulo</h1>
            <p class="rh-meta">Acceso: <span class="rh-pill">@Model.NivelAcceso</span></p>
        </div>
        <a class="rh-btn rh-btn-secondary" asp-controller="Proyectos" asp-action="Details" asp-route-id="@Model.Proyecto.IdProyecto">Volver al proyecto</a>
    </div>

    <div class="rh-grid" style="grid-template-columns: repeat(4, 1fr); margin-bottom: 14px;">
        <div class="rh-card">
            <span class="rh-field-label">Línea de investigación</span>
            <div class="rh-field-value">@(Model.Proyecto.LineaInvestigacion?.Nombre ?? "Sin línea")</div>
            <div class="rh-actions"><a class="rh-btn rh-btn-secondary" asp-action="Relacionados" asp-route-id="@Model.Proyecto.IdProyecto" asp-route-tipo="linea">Ver línea</a></div>
        </div>
        <div class="rh-card">
            <span class="rh-field-label">Sublínea</span>
            <div class="rh-field-value">@(Model.Proyecto.SublineaInvestigacion?.Nombre ?? "Sin sublínea")</div>
            <div class="rh-actions"><a class="rh-btn rh-btn-secondary" asp-action="Relacionados" asp-route-id="@Model.Proyecto.IdProyecto" asp-route-tipo="sublinea">Ver sublínea</a></div>
        </div>
        <div class="rh-card">
            <span class="rh-field-label">Experimentos</span>
            <div class="rh-field-value">@Model.TotalExperimentos</div>
            <div class="rh-actions"><a class="rh-btn rh-btn-secondary" asp-action="Relacionados" asp-route-id="@Model.Proyecto.IdProyecto" asp-route-tipo="experimentos">Ver registros</a></div>
        </div>
        <div class="rh-card">
            <span class="rh-field-label">Muestras</span>
            <div class="rh-field-value">@Model.TotalMuestras</div>
            <div class="rh-actions"><a class="rh-btn rh-btn-secondary" asp-action="Relacionados" asp-route-id="@Model.Proyecto.IdProyecto" asp-route-tipo="muestras">Ver registros</a></div>
        </div>
        <div class="rh-card">
            <span class="rh-field-label">Resultados</span>
            <div class="rh-field-value">@Model.TotalResultados</div>
            <div class="rh-actions"><a class="rh-btn rh-btn-secondary" asp-action="Relacionados" asp-route-id="@Model.Proyecto.IdProyecto" asp-route-tipo="resultados">Ver registros</a></div>
        </div>
        <div class="rh-card">
            <span class="rh-field-label">Análisis</span>
            <div class="rh-field-value">@Model.TotalAnalisis</div>
            <div class="rh-actions"><a class="rh-btn rh-btn-secondary" asp-action="Relacionados" asp-route-id="@Model.Proyecto.IdProyecto" asp-route-tipo="analisis">Ver registros</a></div>
        </div>
        <div class="rh-card">
            <span class="rh-field-label">Validaciones</span>
            <div class="rh-field-value">@Model.TotalValidaciones</div>
            <div class="rh-actions"><a class="rh-btn rh-btn-secondary" asp-action="Relacionados" asp-route-id="@Model.Proyecto.IdProyecto" asp-route-tipo="validaciones">Ver registros</a></div>
        </div>
        <div class="rh-card">
            <span class="rh-field-label">Publicaciones</span>
            <div class="rh-field-value">@Model.TotalPublicaciones</div>
            <div class="rh-actions"><a class="rh-btn rh-btn-secondary" asp-action="Relacionados" asp-route-id="@Model.Proyecto.IdProyecto" asp-route-tipo="publicaciones">Ver registros</a></div>
        </div>
        <div class="rh-card">
            <span class="rh-field-label">Repositorios</span>
            <div class="rh-field-value">@Model.TotalRepositorios</div>
            <div class="rh-actions"><a class="rh-btn rh-btn-secondary" asp-action="Relacionados" asp-route-id="@Model.Proyecto.IdProyecto" asp-route-tipo="repositorios">Ver registros</a></div>
        </div>
        <div class="rh-card">
            <span class="rh-field-label">Colaboradores</span>
            <div class="rh-field-value">@Model.TotalColaboradores</div>
            <div class="rh-actions"><a class="rh-btn rh-btn-secondary" asp-action="Relacionados" asp-route-id="@Model.Proyecto.IdProyecto" asp-route-tipo="colaboradores">Ver equipo</a></div>
        </div>
    </div>

    <div class="rh-grid" style="grid-template-columns: 1fr 1fr; gap: 14px;">
        <div class="rh-card">
            <h3 class="rh-list-title" style="font-size:1.2rem;">Cronograma estratégico</h3>
            <p class="rh-meta">Total fases: @Model.TotalCronograma · Hitos pendientes: @Model.HitosPendientes · Hitos completados: @Model.HitosCompletados</p>
            <div class="rh-actions" style="margin-top:0; margin-bottom:12px;">
                <a class="rh-btn rh-btn-secondary" asp-action="Relacionados" asp-route-id="@Model.Proyecto.IdProyecto" asp-route-tipo="cronograma">Ver cronograma completo</a>
            </div>
            @if (!Model.ProximosHitos.Any())
            {
                <p class="rh-meta">No hay hitos definidos aún.</p>
            }
            else
            {
                <div class="rh-table">
                    <table class="table">
                        <thead><tr><th>Hito</th><th>Fecha</th><th>Estado</th><th>Avance</th></tr></thead>
                        <tbody>
                        @foreach (var h in Model.ProximosHitos)
                        {
                            <tr>
                                <td>@h.NombreFase</td>
                                <td>@(h.FechaFin?.ToString("yyyy-MM-dd") ?? h.FechaInicio?.ToString("yyyy-MM-dd"))</td>
                                <td>@h.Estado</td>
                                <td>@h.PorcentajeAvance%</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="rh-card">
            <h3 class="rh-list-title" style="font-size:1.2rem;">Actividad reciente</h3>
            @if (!Model.EventosRecientes.Any())
            {
                <p class="rh-meta">Sin actividad reciente.</p>
            }
            else
            {
                <div class="rh-table">
                    <table class="table">
                        <thead><tr><th>Tipo</th><th>Título</th><th>Fecha</th><th>Detalle</th></tr></thead>
                        <tbody>
                        @foreach (var e in Model.EventosRecientes)
                        {
                            <tr>
                                <td><span class="rh-pill">@e.Tipo</span></td>
                                <td>@e.Titulo</td>
                                <td>@e.Fecha.ToString("yyyy-MM-dd")</td>
                                <td>@e.Detalle</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
